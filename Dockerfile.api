FROM node:18-alpine

RUN apk add --no-cache tzdata
ENV TZ=America/New_York

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

COPY api-server.js ./
COPY apps/server ./apps/server
RUN mkdir -p /app/uploads && chown node:node /app/uploads

EXPOSE 8080

USER node

CMD ["node", "api-server.js"]

# atyors.com — Local Development Environment
# Copy this file to .env.local and fill in your values

NODE_ENV=development
LOG_LEVEL=debug

# JWT
JWT_SECRET=dev-secret-local-only

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# MongoDB (local docker defaults)
MONGODB_URI=mongodb://admin:password@mongodb:27017/atyors?authSource=admin

# Redis (local docker defaults)
REDIS_URL=redis://redis:6379

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
SKIP_STRIPE=true

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SKIP_TWILIO=true

# Google Maps
GOOGLE_MAPS_API_KEY=

# Email
FROM_EMAIL=noreply@atyors.com

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@atyors.com

# Apple Push Notifications (APNs)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.atyors.app
APNS_KEY_PATH=
APNS_SANDBOX=true

# Frontend (NEXT_PUBLIC_ prefix required for client-side access)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
